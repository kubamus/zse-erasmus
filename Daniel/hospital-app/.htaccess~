RewriteEngine On

# Si existe un archivo o directorio igual al solicitado, se sirve directamente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Si añadiendo .php existe el archivo, se reescribe agregando la extensión
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# Para cualquier otra petición, se redirige a index.php pasando la ruta como parámetro
RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
